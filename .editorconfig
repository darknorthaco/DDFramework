root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{md,toml,yml,yaml,json}]
indent_size = 2

[*.rs]
indent_size = 4

[*.py]
indent_size = 4

[*.c]
indent_size = 4

[*.h]
indent_size = 4

[Makefile]
indent_style = tab
