# Ledger is TRACKED (Constellation §13, Shrike I1 — append-only history
# must be auditable via git). Do not add ledger/*.jsonl to this file.
# Temporary editor backups in the ledger dir, however, are ignored:
ledger/*.jsonl.swp
ledger/*.jsonl.bak
ledger/*.jsonl.tmp

# Rust
target/
**/*.rs.bk
Cargo.lock.tmp

# Python
__pycache__/
*.py[cod]
*$py.class
.Python
.venv/
venv/
env/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# C / build artifacts
*.o
*.obj
*.a
*.so
*.dylib
*.dll
*.exe
*.out

